{
  "name": "hello-ts",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "bun index.ts",
    "dev": "bun --watch index.ts",
    "build": "bun run clean && tsc",
    "clean": "rm -rf dist",
    "test": "bun test",
    "fix": "biome check --write .",
    "check:type": "tsc --noEmit",
    "check:biome": "biome check .",
    "check": "bun run check:type && bun run check:biome && bun run test"
  },
  "engines": {
    "bun": ">=1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.2.0",
    "typescript": "^6.0.2"
  }
}
